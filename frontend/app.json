{
  "expo": {
    "name": "Poker Trainer AI",
    "slug": "frontend",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "frontend",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.emergent.pokertrainerai.k5brb7",
      "infoPlist": {
        "NSCameraUsageDescription": "Capturar screenshots de mesas de poker para análise",
        "NSPhotoLibraryUsageDescription": "Selecionar screenshots de mesas de poker para análise",
        "UIBackgroundModes": [
          "audio"
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#0A1410"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.emergent.pokertrainerai.k5brb7",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_MEDIA_PROJECTION",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.WAKE_LOCK"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-image.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#0A1410"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Selecionar screenshots de poker para análise",
          "cameraPermission": "Capturar screenshots de mesas de poker"
        }
      ],
      "expo-audio",
      "react-native-nitro-screen-recorder"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
